# ---------------------------------------------------------------------------
# PipelinePulse environment variables.
# Copy to `.env` and fill in real values. NEVER commit your real .env file.
# ---------------------------------------------------------------------------

# --- Salesforce (Developer Edition org) ---
SF_USERNAME=you@example.com
SF_PASSWORD=your-salesforce-password
SF_SECURITY_TOKEN=your-salesforce-security-token
# Use "login" for production/dev orgs, "test" for sandboxes.
SF_DOMAIN=login

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Notion ---
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
